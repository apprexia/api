// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(uuid())

  email  String  @unique
  name   String?
  avatar String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  analyses  Analysis[]
  favorites Favorite[]
}

model Analysis {
  id     String @id @default(uuid())
  status String @default("PENDING")
  userId String

  url String

  title String?
  city  String?

  rooms   Int?
  surface Float?

  score              Int?
  scoreExplanation   String?
  verdict            String?
  verdictExplanation String?

  estimatedValue Float?
  askingPrice    Float?

  recommendedPrice Float?

  negotiationAmount Float?

  description String?

  imageUrl String?

  marketPosition String?

  negotiationPotential Int?

  negotiationAnalysis String?

  riskLevel Int?

  grossYield Float?

  yieldLevel String?

  yieldAnalysis String?

  strengths String[]

  risks String[]

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  Favorite Favorite[]
}

model Favorite {
  id String @id @default(uuid())

  userId     String
  analysisId String

  createdAt DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  analysis Analysis @relation(fields: [analysisId], references: [id])

  @@unique([userId, analysisId])
}
