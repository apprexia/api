// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(uuid())

  email  String  @unique
  name   String?
  avatar String?

  // Nombre de crédits disponibles
  credits Int @default(2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  analyses     Analysis[]
  favorites    Favorite[]
  transactions CreditTransaction[]
}

model CreditTransaction {
  id              String                @id @default(uuid())
  userId          String
  amount          Int
  type            CreditTransactionType
  stripeSessionId String?               @unique
  packageId       String?
  description     String?
  createdAt       DateTime              @default(now())
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum CreditTransactionType {
  WELCOME
  ANALYSIS
  PURCHASE
  REFUND
  ADMIN
}

model Analysis {
  id         String  @id @default(uuid())
  status     String  @default("PENDING")
  userId     String
  sourceSite String?
  url        String

  typeLocal  String?
  title      String?
  city       String?
  codePostal String?
  dvfKey     String?

  rooms   Int?
  surface Float?

  score            Int?
  scoreExplanation String?

  verdict            String?
  verdictExplanation String?

  dvfReferenceValue Float?

  estimatedValueLow  Float?
  estimatedValueHigh Float?

  askingPrice      Float?
  recommendedPrice Float?

  negotiationAmount    Float?
  negotiationPotential Int?
  negotiationAnalysis  String?

  marketPosition   String?
  marketAdjustment String?

  riskLevel Int?

  grossYield    Float?
  yieldLevel    String?
  yieldAnalysis String?

  description String?
  imageUrl    String?

  strengths String[]
  risks     String[]

  createdAt DateTime @default(now())

  user     User       @relation(fields: [userId], references: [id])
  Favorite Favorite[]

  @@index([city])
  @@index([codePostal])
  @@index([city, codePostal])
}

enum AnalysisStatus {
  SCRAPING
  SCRAPING_FAILED
  SCRAPED
  AI_PROCESSING
  COMPLETED
  AI_FAILED
  INSUFFICIENT_DATA
}

model Favorite {
  id         String   @id @default(uuid())
  userId     String
  analysisId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  analysis   Analysis @relation(fields: [analysisId], references: [id])

  @@unique([userId, analysisId])
}

model DvfTransaction {
  id             String    @id @default(cuid())
  mutationId     String    @unique
  dateMutation   DateTime?
  year           Int?
  city           String?
  codePostal     String?
  typeLocal      String
  surface        Float
  pieces         Int?
  valeurFonciere Float
  prixM2         Float
  createdAt      DateTime  @default(now())

  @@index([city])
  @@index([codePostal])
  @@index([typeLocal])
  @@index([city, typeLocal])
  @@index([city, codePostal])
  @@index([year, city])
  @@index([year, city, typeLocal])
}
